PORT=8080
NODE_ENV=development

# Required for key-based Google Earth Engine endpoint calls.
GOOGLE_EARTH_API_KEY=your_google_earth_api_key_here

# Earth Engine public project namespace.
EARTH_ENGINE_PROJECT=earthengine-public

# When false, backend still uses your key in config but skips outbound calls.
ENABLE_LIVE_EARTH_CALLS=false

# Optional API tokens for role-based access to mutating endpoints.
ADMIN_API_TOKEN=
ANALYST_API_TOKEN=

# Export bundle output directory.
DATA_EXPORTS_DIR=./data/exports

# Pipeline cadence (hours -> daily by default)
PIPELINE_INTERVAL_HOURS=24

# Master grid setup (2-5 km as per PFD)
DEFAULT_GRID_RESOLUTION_KM=5
DEFAULT_COUNTRY_CODE=UN-DEMO

# Run one full daily pipeline immediately on startup
AUTO_BOOTSTRAP_ON_START=true
